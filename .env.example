# =============================================================================
# NoteSnap Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (NEVER expose in browser - server-side only)
# Used for admin operations that bypass Row Level Security
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -----------------------------------------------------------------------------
# Anthropic (Claude) API Configuration
# Get your key from: https://console.anthropic.com/
# -----------------------------------------------------------------------------

# Anthropic API key for Claude AI image analysis
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# -----------------------------------------------------------------------------
# Recraft V3 API (Visual Generation Playground)
# Get your key from: https://www.recraft.ai/ (profile → Generate API key)
# -----------------------------------------------------------------------------

# Recraft API key for AI image generation
RECRAFT_API_KEY=your-recraft-api-key-here

# -----------------------------------------------------------------------------
# E2B Code Interpreter (Diagram Generation Sandbox)
# Get your key from: https://e2b.dev/
# -----------------------------------------------------------------------------

# E2B API key for sandbox execution
E2B_API_KEY=your-e2b-api-key-here

# Custom E2B template with texlive-full pre-installed (for LaTeX diagrams)
E2B_LATEX_TEMPLATE_ID=your-template-id-here

# -----------------------------------------------------------------------------
# Application Configuration (Optional)
# -----------------------------------------------------------------------------

# Public URL of your deployed app (used for meta tags, redirects, and SEO)
# In development, this defaults to http://localhost:3000
# Production: set to your actual Vercel deployment URL
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Anthropic Claude model to use for AI features
# Default: claude-sonnet-4-6 (recommended for cost/quality balance)
# Options: claude-sonnet-4-6, claude-opus-4-5-20251101
ANTHROPIC_MODEL=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Admin/Support Configuration
# -----------------------------------------------------------------------------

# Admin email for user support and account recovery
NEXT_PUBLIC_ADMIN_EMAIL=support@yourdomain.com
ADMIN_SUPPORT_EMAIL=support@yourdomain.com

# -----------------------------------------------------------------------------
# Development Options (Optional)
# -----------------------------------------------------------------------------

# Set to 'development' or 'production'
NODE_ENV=development

# -----------------------------------------------------------------------------
# AI Model Configuration (Optional)
# -----------------------------------------------------------------------------

# Fast model for lightweight AI operations (defaults to claude-sonnet-4-6)
# ANTHROPIC_MODEL_FAST=claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Email Configuration (Optional — required for password reset & weekly reports)
# Get your key from: https://resend.com/
# -----------------------------------------------------------------------------

# Resend API key for transactional emails
# RESEND_API_KEY=re_your-resend-api-key-here

# Sender email address (must be verified in Resend)
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# External API Keys (Optional — features degrade gracefully without these)
# -----------------------------------------------------------------------------

# Google AI API key for image generation fallback
# Get from: https://aistudio.google.com/apikey
# GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Unsplash API key for cover image search
# Get from: https://unsplash.com/developers
# UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# YouTube Data API key for video search in study guides
# Get from: https://console.cloud.google.com/apis/credentials
# YOUTUBE_DATA_API_KEY=your-youtube-api-key-here

# -----------------------------------------------------------------------------
# Cron Job Security (Required if using Vercel cron jobs)
# -----------------------------------------------------------------------------

# Secret token to authenticate cron job requests
# Generate with: openssl rand -base64 32
# Must match the value in Vercel environment variables
# CRON_SECRET=your-cron-secret-here

# -----------------------------------------------------------------------------
# Feature Flags (Optional — all default to disabled/safe values)
# -----------------------------------------------------------------------------

# Enable smart diagram generation pipeline (default: false)
# SMART_PIPELINE_ENABLED=false

# Enable smart homework solver (default: false)
# SMART_SOLVER_ENABLED=false

# Enable diagram step capture (default: true)
# STEP_CAPTURE_ENABLED=true

# -----------------------------------------------------------------------------
# Rate Limiting (Optional — disabled by default)
# Format: "maxRequests,windowMs" (e.g., "30,60000" = 30 requests per minute)
# -----------------------------------------------------------------------------

# Set to 'true' to disable all rate limiting (default: true)
# RATE_LIMIT_DISABLED=true

# Per-endpoint rate limits (format: maxRequests,windowMs)
# RATE_LIMIT_GENERATE_COURSE=5,60000
# RATE_LIMIT_GENERATE_EXAM=10,60000
# RATE_LIMIT_GENERATE_QUESTIONS=20,60000
# RATE_LIMIT_CHAT=30,60000
# RATE_LIMIT_EVALUATE_ANSWER=30,60000
# RATE_LIMIT_UPLOAD=20,60000
# RATE_LIMIT_SEARCH=50,60000
# RATE_LIMIT_LOGIN=10,900000
# RATE_LIMIT_FORGOT_PASSWORD=5,3600000
